{
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "lib", "dist", "**/*.spec.ts", "**/*.test.ts"],
  "compilerOptions": {
    "strict": true,
    "outDir": "lib",
    "target": "ES2022",
    "lib": ["ES2022"],
    "sourceMap": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "baseUrl": ".",
    "types": ["node"],
    "skipLibCheck": true
  }
}
