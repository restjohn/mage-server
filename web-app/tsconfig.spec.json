{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": [
      "jasmine",
      "node"
    ]
  },
  "files": [
    "src/test.ts",
    "src/polyfills.ts",
  ],
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "admin/src/**/*.spec.ts",
    "admin/src/**/*.d.ts",
    "admin/src/**/*.ts",
    "core-lib-src/**/*.ts",
  ]
}
